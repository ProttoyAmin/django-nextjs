########################################
# MEMBER MANAGEMENT ---WORKS---
########################################


### Promote to Admin -- Works---
PATCH {{baseUrl}}{{clubId}}/members/{{userId}}/role/
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "role": "admin"
}


### Demote to Member -- Works---
PATCH {{baseUrl}}{{clubId}}/members/{{userId}}/role/
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "role": "member"
}


### Update Member Role (Admin Only) -- WORKS ----
PATCH {{baseUrl}}{{clubId}}/members/{{userId}}/role/
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "role": "moderator"
}


### Remove Member (Admin/Moderator Only) -- WORKS ----
DELETE {{baseUrl}}{{clubId}}/members/{{userId}}/remove/
Authorization: Bearer {{accessToken}}



